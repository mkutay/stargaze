// Project-local debug tasks for stargaze (C++ chess engine)
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
    {
        // Build the debug binary (with -g, ASan, UBSan) then launch it
        "label": "Build & Debug (stargaze)",
        "adapter": "CodeLLDB",
        "request": "launch",
        "program": "$ZED_WORKTREE_ROOT/bin/stargaze",
        "cwd": "$ZED_WORKTREE_ROOT",
        "terminal": "integrated",
        "build": {
            "command": "make",
            "args": ["debug"],
            "cwd": "$ZED_WORKTREE_ROOT",
        },
    },
    {
        // Launch an already-compiled debug binary without rebuilding
        "label": "Launch (no rebuild)",
        "adapter": "CodeLLDB",
        "request": "launch",
        "program": "$ZED_WORKTREE_ROOT/bin/stargaze",
        "cwd": "$ZED_WORKTREE_ROOT",
        "terminal": "integrated",
    },
    {
        // Attach to a running stargaze process (shows a process picker)
        "label": "Attach to stargaze",
        "adapter": "CodeLLDB",
        "request": "attach",
        "pid": "${command:pickProcess}",
    },
    {
        // Build the tests binary then debug under CodeLLDB
        "label": "Build & Debug Tests (stargaze_tests)",
        "adapter": "CodeLLDB",
        "request": "launch",
        "program": "$ZED_WORKTREE_ROOT/bin/stargaze_tests",
        "cwd": "$ZED_WORKTREE_ROOT",
        "terminal": "integrated",
        "build": {
            "command": "make",
            "args": ["bin/stargaze_tests"],
            "cwd": "$ZED_WORKTREE_ROOT",
        },
    },
]
